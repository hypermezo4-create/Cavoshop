// Cavo Prisma Schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Product {
  id          String     @id @default(cuid())
  name        String
  codename    String     @unique
  brand       String
  chipset     String
  status      String     @default("ACTIVE")
  image       String?
  description String?
  collections        Rom[]
  orders   Order[]
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
}

model Rom {
  id                String   @id @default(cuid())
  productId          String
  product            Product   @relation(fields: [productId], references: [id], onDelete: Cascade)
  name              String
  version           String
  androidVersion     String
  type              String   @default("FREE")
  orderUrl       String
  fileSize          String?
  changelog         String?
  releaseDate       DateTime @default(now())
  gallery       String[]
  installationGuide String?
  status            String   @default("ACTIVE")
  isVipOnly         Boolean  @default(false)
  orders         Order[]
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

model Order {
  id           String   @id @default(cuid())
  romId        String
  productId     String?
  ipAddress    String?
  userAgent    String?
  country      String?
  city         String?
  orderedAt DateTime @default(now())

  rom    Rom     @relation(fields: [romId], references: [id], onDelete: Cascade)
  product Product? @relation(fields: [productId], references: [id], onDelete: SetNull)

  @@index([romId])
  @@index([productId])
  @@index([orderedAt])
  @@index([country])
}

model StaffMember {
  id        String   @id @default(cuid())
  name      String
  role      String
  country   String?
  image     String?
  bio       String?
  instagram    String?
  whatsapp  String?
  twitter   String?
  website   String?
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model SiteConfig {
  key       String   @id
  value     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Faq {
  id        String   @id @default(cuid())
  question  String
  answer    String
  category  String
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ContactForm {
  id        String   @id @default(cuid())
  name      String
  email     String
  type      String   // 'bug', 'feature', 'general'
  subject   String
  message   String
  status    String   @default("new") // 'new', 'read', 'resolved'
  createdAt DateTime @default(now())
}

model Screenshot {
  id          String   @id @default(cuid())
  title       String
  imageUrl    String
  description String?
  category    String?
  order       Int      @default(0)
  createdAt   DateTime @default(now())
}

model SocialLink {
  id        String   @id @default(cuid())
  platform  String   // 'instagram', 'whatsapp', 'discord', 'twitter'
  url       String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}


